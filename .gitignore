# --- Monolythium base .gitignore (applies to every repo) ---

# Local-only development context (NEVER push these)
CLAUDE.md
.claude/local/
.claude/skills/
.gemini/
plans/
docs-internal/
*.internal.md
AUDIT-*.md
RESUME.md
STATUS.md
TODO.md

# Environment + secrets
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.keystore
*.p12
secrets/
credentials/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
!.vscode/settings.recommended.json
*.iml

# Local scratch
scratch/
tmp/
.cache/

# Logs
*.log
logs/
# --- Rust additions (append to gitignore.base) ---
target/
**/target/
Cargo.lock
# For library crates, uncomment the next line to commit Cargo.lock anyway.
# !Cargo.lock
*.rs.bk
rustc-ice-*.txt
# --- Node / TS / Vite additions (append to gitignore.base) ---
node_modules/
dist/
!packages/ts/dist/
!packages/ts/dist/**
dist-ssr/
build/
.vite/
.vitest-cache/
.astro/
.next/
.turbo/
.nuxt/
.svelte-kit/
coverage/
*.tsbuildinfo
.pnpm-store/
.pnp.*
.yarn/

# Lockfiles: keep pnpm-lock.yaml; drop others if pnpm is the workspace's package manager
# package-lock.json
# yarn.lock

# Pack artifacts
*.tgz

# Rust-side ts-rs bindings are intermediate — synced into packages/ts/src/bindings/
crates/core-sdk/bindings/
