{
  "name": "@monolythium/core-sdk",
  "version": "0.3.12",
  "description": "Official TypeScript SDK for Monolythium / LythiumDAG-BFT",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monolythium/mono-core-sdk.git",
    "directory": "packages/ts"
  },
  "homepage": "https://github.com/monolythium/mono-core-sdk#readme",
  "bugs": "https://github.com/monolythium/mono-core-sdk/issues",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.js",
      "require": "./dist/crypto/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:smoke": "bash scripts/pnpm-pack-smoke.sh"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "@noble/ciphers": "2.2.0",
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.2.0",
    "@noble/post-quantum": "0.6.1",
    "@scure/bip39": "2.2.0"
  }
}
