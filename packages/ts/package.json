{
  "name": "@monolythium/core-sdk",
  "version": "0.2.1",
  "description": "Official TypeScript SDK for Monolythium v4.1 / LythiumDAG-BFT",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monolythium/mono-core-sdk.git",
    "directory": "packages/ts"
  },
  "homepage": "https://github.com/monolythium/mono-core-sdk#readme",
  "bugs": "https://github.com/monolythium/mono-core-sdk/issues",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.js",
      "require": "./dist/crypto/index.cjs"
    },
    "./ethers": {
      "types": "./dist/ethers/index.d.ts",
      "import": "./dist/ethers/index.js",
      "require": "./dist/ethers/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:smoke": "bash scripts/pnpm-pack-smoke.sh"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "ethers": "^6.16.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.2",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "ethers": "^6.16.0"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": true
    }
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@noble/post-quantum": "^0.6.1",
    "@scure/bip39": "^2.2.0"
  }
}
